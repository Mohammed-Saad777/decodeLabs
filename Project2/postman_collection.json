{
  "info": {
    "name": "Student Management REST API",
    "description": "Postman collection for the Node.js + Express Student Management REST API. Base URL variable: {{baseUrl}} (default http://localhost:5000).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "b3a1e2b0-1a2b-4c3d-9e5f-abcdef012345"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Get All Students",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/students?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "students"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" },
            { "key": "search", "value": "", "disabled": true },
            { "key": "course", "value": "", "disabled": true },
            { "key": "sortBy", "value": "name", "disabled": true },
            { "key": "order", "value": "asc", "disabled": true }
          ]
        }
      }
    },
    {
      "name": "Get Student By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/students/{{studentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "students", "{{studentId}}"]
        }
      }
    },
    {
      "name": "Create Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json && json.data && json.data.id) {",
              "    pm.collectionVariables.set('studentId', json.data.id);",
              "    console.log('Saved studentId =', json.data.id);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Priya Kapoor\",\n  \"email\": \"priya@example.com\",\n  \"age\": 22,\n  \"course\": \"Computer Science\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/students",
          "host": ["{{baseUrl}}"],
          "path": ["api", "students"]
        }
      }
    },
    {
      "name": "Update Student",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"age\": 23,\n  \"course\": \"Data Science\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/students/{{studentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "students", "{{studentId}}"]
        }
      }
    },
    {
      "name": "Delete Student",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/students/{{studentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "students", "{{studentId}}"]
        }
      }
    },
    {
      "name": "Search / Filter / Sort / Paginate",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/students?search=a&course=Computer Science&sortBy=age&order=desc&page=1&limit=5",
          "host": ["{{baseUrl}}"],
          "path": ["api", "students"],
          "query": [
            { "key": "search", "value": "a" },
            { "key": "course", "value": "Computer Science" },
            { "key": "sortBy", "value": "age" },
            { "key": "order", "value": "desc" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "5" }
          ]
        }
      }
    },
    {
      "name": "Validation Error (missing fields)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"\",\n  \"email\": \"not-an-email\",\n  \"age\": 12\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/students",
          "host": ["{{baseUrl}}"],
          "path": ["api", "students"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "studentId", "value": "" }
  ]
}
